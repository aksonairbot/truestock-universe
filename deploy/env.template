# Truestock Universe — production env
# Copy to /etc/truestock/env on the droplet (chmod 600, owned by truestock:truestock)

# -----------------------------------------------------------------------------
# Database — DO Managed Postgres (Dev tier)
# -----------------------------------------------------------------------------
# From the cluster's "Connection Pool → Public network" string, append ?sslmode=require
DATABASE_URL=postgres://doadmin:PASSWORD@db-postgresql-blr1-xxxxx-do-user-xxxxx-0.e.db.ondigitalocean.com:25061/defaultdb?sslmode=require

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
# Test mode keys first (rzp_test_xxxxx). Switch to rzp_live_xxxxx after Phase 0 validation.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Set the same value in the Razorpay dashboard when adding the webhook.
# Generate: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Internal
# -----------------------------------------------------------------------------
# Protects /api/sync/* and /api/cron/* endpoints. Generate with:  openssl rand -hex 32
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# Public URL (used in emails, webhooks, deep links)
NEXT_PUBLIC_APP_URL=https://universe.truestock.in

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Sentry (uncomment + install @sentry/node to enable error forwarding)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Runtime
NODE_ENV=production
PORT=3000
