{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "drizzle:generate": { "cache": false },
    "drizzle:push": { "cache": false },
    "drizzle:studio": { "cache": false, "persistent": true },
    "seed": { "cache": false }
  }
}
