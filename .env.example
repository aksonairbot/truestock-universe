# -----------------------------------------------------------------------------
# Truestock Universe — environment variables
# Copy to `.env` (repo root) for local dev. On DO App Platform, set these as
# per-component env vars, not as a file.
# -----------------------------------------------------------------------------

# Postgres connection (DO Managed Postgres)
# Local docker: postgres://postgres:postgres@localhost:5432/truestock
# Managed: postgres://doadmin:xxxxx@db-xxxxx.do-user-xxxxx.db.ondigitalocean.com:25060/defaultdb?sslmode=require
DATABASE_URL="postgres://postgres:postgres@localhost:5432/truestock"

# Razorpay credentials (get from dashboard.razorpay.com)
# Use TEST keys locally (rzp_test_...), LIVE keys in prod only
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook secret — set a strong random string here AND in Razorpay dashboard
# (Razorpay → Settings → Webhooks → add webhook → enter this as the secret)
RAZORPAY_WEBHOOK_SECRET="change-me-to-a-long-random-string"

# Internal sync/cron auth — protects the /api/sync/* and /api/cron/* endpoints
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET="change-me-to-a-long-random-string"

# App URL (used for webhook registration, email links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node env
NODE_ENV="development"

# Sentry — optional. If unset, errors only land in stdout (still visible in DO logs).
# Install @sentry/node in apps/web to enable forwarding.
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
