{
  "name": "truestock-universe",
  "version": "0.1.0",
  "private": true,
  "description": "Truestock Universe — internal MIS, marketing engine, and task manager",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @tu/db drizzle:generate",
    "db:push": "pnpm --filter @tu/db drizzle:push",
    "db:migrate": "pnpm --filter @tu/db migrate",
    "db:seed": "pnpm --filter @tu/db seed",
    "db:studio": "pnpm --filter @tu/db drizzle:studio",
    "razorpay:backfill": "pnpm --filter web exec tsx scripts/backfill-razorpay.ts"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.4",
    "vitest": "^2.1.3",
    "@vitest/coverage-v8": "^2.1.3"
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9"
  }
}
